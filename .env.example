# =========================
# DOMAIN CONFIGURATION
# =========================
DOMAIN=localhost
LETSENCRYPT_EMAIL=admin@example.com

# =========================
# DATA DIRECTORY
# =========================
DATA_DIR=./data

# =========================
# POSTGRES CONFIGURATION
# =========================
POSTGRES_DB=scraper
POSTGRES_USER=scraper
# POSTGRES_PASSWORD - sätts via secrets/postgres_password.txt

# =========================
# REDIS CONFIGURATION
# =========================
# REDIS_PASSWORD - sätts via secrets/redis_password.txt

# =========================
# SCRAPER CONFIGURATION
# =========================
CONCURRENT_PAGES=3
HEADLESS=true
SCRAPE_INTERVAL=3600
MAX_PAGES_PER_SITE=50

# =========================
# RATE LIMITING
# =========================
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_PERIOD=60

# =========================
# ALERTS CONFIGURATION
# =========================
ALERT_CHECK_INTERVAL=1800
MIN_DROP_PERCENT=5
MIN_DROP_AMOUNT=100
COOLDOWN_HOURS=24

# =========================
# GRAFANA CONFIGURATION
# =========================
GRAFANA_USER=admin
# GRAFANA_PASSWORD - sätts via secrets/grafana_password.txt

# =========================
# PROXY CONFIGURATION
# =========================
PROXY_LIST_URL=
PROXY_ROTATION_INTERVAL=300

# =========================
# NOTIFICATION WEBHOOKS (sätts via secrets)
# =========================
# DISCORD_WEBHOOK - sätts via secrets/discord_webhook.txt
# SLACK_WEBHOOK - sätts via secrets/slack_webhook.txt
# TELEGRAM_BOT_TOKEN
# TELEGRAM_CHAT_ID
