# =========================
# DATA DIRECTORY
# =========================
DOCKER=/path/to/docker/data
CONFIG=/path/to/config

# =========================
# SCRAPER CONFIGURATION
# =========================
CONCURRENT_PAGES=3
HEADLESS=true
SCRAPE_INTERVAL=3600

# =========================
# ALERTS CONFIGURATION
# =========================
ALERT_CHECK_INTERVAL=1800
MIN_DROP_PERCENT=5
MIN_DROP_AMOUNT=100
COOLDOWN_HOURS=24

# =========================
# PORTS
# =========================
WEBUI_PORT=3000
API_PORT=8000
DOMAIN=example.com
