# Minimal required configuration.
# Copy to .env and fill in your values.
#
# All other settings (scrape interval, alert thresholds, proxy, etc.)
# are configured in the WebUI under Advanced settings.

DOCKER=/path/to/docker/data   # where volumes are stored
DOMAIN=example.com             # used for reverse proxy labels
TZ=Europe/Stockholm            # timezone (IANA format)
