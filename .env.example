# =========================
# PATHS
# =========================
DOCKER=/path/to/docker/data
CONFIG=/path/to/config
DOMAIN=example.com

# =========================
# SCRAPER
# =========================
CONCURRENT_PAGES=3
HEADLESS=true
SCRAPE_INTERVAL=3600

# =========================
# ALERTS
# =========================
ALERT_CHECK_INTERVAL=1800
MIN_DROP_PERCENT=5
MIN_DROP_AMOUNT=100
COOLDOWN_HOURS=24

# =========================
# SECURITY
# =========================
API_KEY=your-secure-api-key-here
